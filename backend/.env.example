# ==========================================
# CLOUD STORAGE - ENVIRONMENT TEMPLATE
# ==========================================
# Copia questo file in .env e inserisci i tuoi valori reali
# NON committare il file .env su GitHub!

# Database Configuration
# Neon DB: vai su neon.tech e copia la connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Oppure variabili singole (alternativa a DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloud_storage_db
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# Server Configuration
NODE_ENV=production
PORT=5000
API_URL=https://your-backend.onrender.com

# JWT Configuration - Genera chiavi casuali sicure!
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=GENERATE_ANOTHER_RANDOM_64_CHAR_HEX_STRING
REFRESH_TOKEN_EXPIRY=30d

# Encryption (AES-256)
# Deve essere esattamente 64 caratteri hex (32 bytes)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=GENERATE_A_64_CHAR_HEX_STRING

# File Upload Configuration
MAX_FILE_SIZE=52428800
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,application/zip

# Security
# Metti qui l'URL del tuo frontend (es. https://nome.vercel.app)
CORS_ORIGIN=https://your-frontend.vercel.app
SESSION_SECRET=GENERATE_A_RANDOM_SECRET_STRING

# Telegram Bot Configuration (opzionale)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_NAME=@YourBot
SUPPORT_EMAIL=support@yourdomain.com

# Logging
LOG_LEVEL=info

# Email Configuration (OTP & Notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend URL for share links
FRONTEND_URL=https://rorycloud.vercel.app
